        "predeploy": "pnpm build && pnpm export",
        "deploy": "gh-pages -b master -d out"
    },
    "devDependencies": {
        "@types/node": "22.13.4",
        "@types/react": "18.3.18",
        "@types/react-dom": "18.3.5",
