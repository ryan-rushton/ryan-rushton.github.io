{
    "name": "ryan-rushton.github.io",
    "version": "1.0.0",
    "private": true,
    "homepage": "https://ryan-rushton.github.io",
    "dependencies": {
        "next": "14.2.20",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "react-icons": "5.2.1",
        "react-tsparticles": "2.12.2",
        "sass": "1.77.8"
    },
    "scripts": {
        "build": "next build",
        "dev": "next dev",
        "export": "next export",
        "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
        "lint": "eslint ./src --ext .js,.jsx,.ts,.tsx",
        "type-check": "tsc --noEmit",
